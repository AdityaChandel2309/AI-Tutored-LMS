# ──────────────────────────────────────────────────
# LMS Production Environment Variables
# Copy to .env and fill in all values before deploying.
#
# IMPORTANT: leave AUTO_SEED_DEMO=false on production images so the api
# container never seeds demo data on startup.
AUTO_SEED_DEMO=false
# ──────────────────────────────────────────────────

# ── Domain ───────────────────────────────────────
# Your production domain (used for CORS, Keycloak redirects, etc.)
DOMAIN=lms.example.com
HTTP_PORT=80
# HTTPS_PORT=443

# ── PostgreSQL ───────────────────────────────────
POSTGRES_DB=keycloak
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
LMS_DB_NAME=lms

# ── Keycloak ─────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_strong_password_here
KEYCLOAK_BASE_URL=https://lms.example.com/auth
KEYCLOAK_REALM=LMS
KEYCLOAK_CLIENT_ID=lms-web
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_REDIRECT_URI=https://lms.example.com/callback

# ── MinIO (S3-compatible storage) ────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_password_here
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_REGION=us-east-1
MINIO_BUCKET=lms-avatars
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_BASE_URL=https://lms.example.com/storage
SCORM_BUCKET=lms-scorm
SCORM_UPLOAD_MAX_BYTES=1073741824
SCORM_PRESIGN_UPLOAD_TTL_SEC=900

# ── API ──────────────────────────────────────────
API_PUBLIC_URL=https://lms.example.com/api
CORS_ORIGINS=https://lms.example.com
FRONTEND_APP_URL=https://lms.example.com

# ── Web (build-time NEXT_PUBLIC_ vars) ───────────
NEXT_PUBLIC_API_URL=https://lms.example.com/api
NEXT_PUBLIC_KEYCLOAK_URL=https://lms.example.com/auth
NEXT_PUBLIC_KEYCLOAK_REALM=LMS
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=lms-web
NEXT_PUBLIC_APP_URL=https://lms.example.com
NEXT_PUBLIC_DEFAULT_TENANT_SUBDOMAIN=default
