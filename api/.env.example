DATABASE_URL="postgresql://postgres:change_this_postgres_password@localhost:5432/lms"

PORT=3000
HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
FRONTEND_APP_URL=http://localhost:3001

# Keycloak — BOTH URLs are required. BASE_URL is the browser-facing URL
# (used to validate token `iss` claims from user logins). INTERNAL_URL is
# how the API reaches Keycloak (host-to-container on localhost, or the
# `keycloak` service name inside Docker). Missing KEYCLOAK_BASE_URL causes
# every direct-grant sign-in to 401 with "issuer invalid".
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_INTERNAL_URL=http://localhost:8080
KEYCLOAK_REALM=LMS
KEYCLOAK_CLIENT_ID=lms-web
KEYCLOAK_CLIENT_SECRET=replace_with_keycloak_client_secret
KEYCLOAK_REDIRECT_URI=http://localhost:3001/callback

# Keycloak admin (used by the provisioner + user-seed scripts)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin123
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli

MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_BASE_URL=http://localhost:9000
MINIO_BUCKET=lms-avatars
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
SCORM_BUCKET=lms-scorm
SCORM_UPLOAD_MAX_BYTES=1073741824
SCORM_PRESIGN_UPLOAD_TTL_SEC=900

# Feature Flags (set to true or 1 to enable)
FEATURE_AI_TUTOR=true
FEATURE_KNOWLEDGE_ASSISTANT=true
FEATURE_SCORM=true
FEATURE_CERTIFICATES=true
FEATURE_PROJECTS=true
FEATURE_CSV_IMPORT=true
